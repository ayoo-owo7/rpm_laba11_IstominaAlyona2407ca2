<UserControl x:Class="Rpm_Lab11.Views.ContactEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Rpm_Lab11.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel>
        <TextBlock Text="Редактирование контакта" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
        <TextBox Text="{Binding EditPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
        <StackPanel Orientation="Horizontal">
            <Button Content="Сохранить" Command="{Binding SaveCommand}" Margin="0,0,10,0" Padding="15,5"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" Padding="15,5"/>
        </StackPanel>
    </StackPanel>
</UserControl>
