<Window x:Class="Rpm_Lab11.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Rpm_Lab11"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="LightGray" Height="35">
            <Button Content="Контакты" Command="{Binding ShowContactsCommand}" Margin="10,5" Padding="10,2"/>
            <Button Content="О программе" Command="{Binding ShowAboutCommand}" Margin="10,5" Padding="10,2"/>
        </StackPanel>
        <ContentControl Content="{Binding NavigationService.CurrentViewModel}"/>
    </DockPanel>
</Window>
